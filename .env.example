# Django secret key
SECRET_KEY=your-secret-key

# Debug mode: True or False
DEBUG=False

# Database settings (used by Django's DATABASES config)
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Superuser credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword

# JSON Builder DB (separate from main app DB)
# Example values for the JSON builder database used by scheduled builders.
JSON_BUILDER_DB_HOST=your_json_builder_db_host
JSON_BUILDER_DB_PORT=3306
JSON_BUILDER_DB_USER=your_json_builder_db_user
JSON_BUILDER_DB_PASSWORD=your_json_builder_db_password
JSON_BUILDER_DB_NAME=your_json_builder_db_name
